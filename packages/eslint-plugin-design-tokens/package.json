{
  "name": "@kong/eslint-plugin-design-tokens",
  "version": "1.0.3",
  "type": "module",
  "description": "ESLint plugin for Kong UI design tokens",
  "exports": {
    ".": "./index.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "index.mjs",
    "rules",
    "utilities",
    "README.md"
  ],
  "peerDependencies": {
    "eslint": "^9.0.0",
    "vue-eslint-parser": ">=10.2.0"
  },
  "peerDependenciesMeta": {
    "vue-eslint-parser": {
      "optional": true
    }
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.59.4",
    "vitest": "^4.1.9"
  },
  "scripts": {
    "lint": "eslint .",
    "test": "vitest run --config vitest.config.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Kong/design-tokens.git"
  },
  "homepage": "https://github.com/Kong/design-tokens/packages/eslint-plugin-design-tokens/",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.19.5",
    "pnpm": ">=10.28.2"
  }
}
