{
  "name": "@kong/design-tokens",
  "version": "3.0.3",
  "description": "Kong Design Tokens and style dictionary",
  "private": false,
  "type": "module",
  "scripts": {
    "build": "pnpm build:clean && pnpm build:tokens && pnpm copy:tokens-doc",
    "build:tokens": "style-dictionary build --config ./config.mjs",
    "build:clean": "rimraf ./dist",
    "copy:tokens-doc": "shx cp -f './dist/tokens/README.md' './TOKENS.md'",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "pnpm typecheck:sandbox",
    "typecheck:sandbox": "vue-tsc --project ./sandbox/tsconfig.json --noEmit",
    "sandbox": "pnpm build && run-p sandbox:open sandbox:watch",
    "sandbox:open": "vite sandbox -c ./sandbox/vite.config.ts",
    "sandbox:watch": "chokidar \"tokens/**/*.json\" \"themes/**/*.json\" -c \"pnpm build\"",
    "sandbox:build": "BUILD_SANDBOX=true vite build -c ./sandbox/vite.config.ts -m production",
    "sandbox:preview": "BUILD_SANDBOX=true vite preview -c ./sandbox/vite.config.ts",
    "watch:tokens": "pnpm build && chokidar \"tokens/**/*.json\" -c \"pnpm build\"",
    "theme:scaffold": "node scripts/theme-scaffold.mjs",
    "theme:preview": "node ../skills/theme-creation/scripts/preview.mjs",
    "themes:sync": "node scripts/themes-sync.mjs",
    "themes:unfilled": "node scripts/themes-unfilled.mjs",
    "pretest": "pnpm build:tokens",
    "test": "vitest run --config vitest.config.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "TOKENS.md"
  ],
  "main": "dist/tokens/js/cjs/index.js",
  "module": "dist/tokens/js/index.mjs",
  "types": "dist/tokens/js/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/tokens/js/index.d.ts",
        "default": "./dist/tokens/js/index.mjs"
      },
      "require": {
        "types": "./dist/tokens/js/cjs/index.d.ts",
        "default": "./dist/tokens/js/cjs/index.js"
      }
    },
    "./themes": {
      "import": {
        "types": "./dist/themes/index.d.ts",
        "default": "./dist/themes/index.mjs"
      },
      "require": {
        "types": "./dist/themes/index.d.cts",
        "default": "./dist/themes/index.cjs"
      }
    },
    "./themes/*.css": "./dist/themes/*.css",
    "./themes/*": {
      "import": {
        "types": "./dist/themes/*.d.ts",
        "default": "./dist/themes/*.mjs"
      },
      "require": {
        "types": "./dist/themes/*.d.cts",
        "default": "./dist/themes/*.cjs"
      }
    },
    "./tokens/themeable-tokens": {
      "import": {
        "types": "./dist/tokens/themeable-tokens/index.d.ts",
        "default": "./dist/tokens/themeable-tokens/index.mjs"
      },
      "require": {
        "types": "./dist/tokens/themeable-tokens/index.d.cts",
        "default": "./dist/tokens/themeable-tokens/index.cjs"
      }
    },
    "./tokens/*": "./dist/tokens/*",
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Kong/design-tokens.git"
  },
  "author": "Kong Inc.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Kong/design-tokens/packages/design-tokens/",
  "bugs": {
    "url": "https://github.com/Kong/design-tokens/issues"
  },
  "devDependencies": {
    "style-dictionary": "^5.4.4"
  },
  "engines": {
    "node": ">=20.19.5",
    "pnpm": ">=10.28.2"
  },
  "volta": {
    "node": "24.13.1"
  }
}
