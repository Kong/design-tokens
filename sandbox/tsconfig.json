{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@/*": [
        "./*"
      ],
      "@tokens/*": [
        "../dist/tokens/*"
      ]
    },
  },
  "include": [
    "**/*.ts",
    "**/*.vue"
  ],
  "exclude": [
    "node_modules",
    "vite.config.ts",
    "vite-preview-proxy.ts"
  ]
}
