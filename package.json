{
  "name": "@kong/design-tokens-monorepo",
  "private": true,
  "scripts": {
    "build": "FORCE_COLOR=1 pnpm -r build",
    "lint": "FORCE_COLOR=1 pnpm -r lint",
    "lint:fix": "FORCE_COLOR=1 pnpm -r lint:fix",
    "typecheck": "FORCE_COLOR=1 pnpm -r typecheck",
    "test": "FORCE_COLOR=1 pnpm -r test",
    "sandbox:design-tokens": "FORCE_COLOR=1 pnpm --filter @kong/design-tokens sandbox",
    "sandbox:design-tokens:build": "FORCE_COLOR=1 pnpm --filter @kong/design-tokens sandbox:build",
    "commit": "cz"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@digitalroute/cz-conventional-changelog-for-jira": "^8.0.1",
    "@evilmartians/lefthook": "^2.1.2",
    "@kong/eslint-config-kong-ui": "^1.7.1",
    "@lerna-lite/changed": "^5.2.2",
    "@lerna-lite/cli": "^5.2.2",
    "@lerna-lite/list": "^5.2.2",
    "@lerna-lite/publish": "^5.2.2",
    "@lerna-lite/version": "^5.2.2",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitejs/plugin-vue": "^6.0.4",
    "chokidar-cli": "^3.0.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.9.0",
    "npm-run-all2": "^8.0.4",
    "rimraf": "^6.1.3",
    "sass": "^1.97.3",
    "shx": "^0.4.0",
    "style-dictionary": "^5.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.0",
    "vite-plugin-restart": "^2.0.0",
    "vite-plugin-vue-devtools": "^8.0.7",
    "vitest": "^4.1.5",
    "vue": "^3.5.29",
    "vue-eslint-parser": "^10.4.0",
    "vue-router": "^5.0.3",
    "vue-tsc": "^3.2.7"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/@digitalroute/cz-conventional-changelog-for-jira",
      "skipScope": false,
      "jiraOptional": true,
      "jiraLocation": "post-description",
      "jiraPrepend": "[",
      "jiraAppend": "]"
    }
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20.19.5",
    "pnpm": ">=10.28.2"
  },
  "volta": {
    "node": "24.13.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@bundled-es-modules/glob",
      "@evilmartians/lefthook",
      "esbuild",
      "style-dictionary"
    ],
    "overrides": {
      "semver": "^7.6.0"
    }
  }
}
